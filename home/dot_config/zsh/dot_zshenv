# Provide _debug functionality as early as possible
_debug() {
  if [[ -n ${ZSH_DEBUG-} ]]; then
    echo "[ZSH] $1"
  fi
}

# Usage: _require_commands <plugin_name> <cmd> [cmd...]
# Returns 1 and skips loading if any command is missing.
#
# Example:
#   _require_commands "go.plugin.zsh" go gofmt || return
#
_require_commands() {
  local plugin="$1"
  shift

  for cmd in "$@"; do
    if (( ! $+commands[$cmd] )); then
      _debug "Skipping $plugin (missing: $cmd)"
      return 1
    fi
  done

  _debug "Loading $plugin"
}

# Usage: _require_dirs <dir> [dir...]
# Returns 1 and skips loading if any directory is missing.
#
# Example:
#   _require_dirs "$CARGO_HOME/bin" || return
#
_require_dirs() {
  local plugin="$1"
  shift

  for dir in "$@"; do
    if [[ ! -d "$dir" ]]; then
      _debug "Skipping $plugin (missing directory: $dir)"
      return 1
    fi
  done

  _debug "Loading $plugin"
}
